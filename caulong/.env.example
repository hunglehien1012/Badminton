# ─── FILE MẪU CẤU HÌNH MÔI TRƯỜNG ─────────────────────────────────
# Dự án hiện là static site (không bundler) nên cấu hình Firebase đang
# nằm trong src/constants/config.js. Khi chuyển sang Vite/Webpack,
# hãy chuyển các giá trị đó vào file .env (copy từ file này) và đọc
# qua import.meta.env / process.env.

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id

ADMIN_EMAIL=admin@badminton.local
ADMIN_UID=paste_admin_uid_here
